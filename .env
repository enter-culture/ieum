# 배포(production) 기본값 — git에 커밋되는 env 파일.
# 로컬에서는 .env.local(gitignore)이 이 값을 덮어쓴다. 빌드 서버엔 .env.local이 없어 이 값이 쓰인다.

# 백엔드(ieum-api) 주소 — 모든 데이터 API + OAuth 콜백이 여기로 호출/생성된다.
NEXT_PUBLIC_API_BASE_URL=https://ieum-api.onrender.com/api

# R2 공개 URL — 업로드 후 재생 URL 구성에 사용 (클라이언트 노출)
NEXT_PUBLIC_R2_PUBLIC_URL=https://pub-fbeeb1fbba2e414eaccb124f1c63e3cd.r2.dev
